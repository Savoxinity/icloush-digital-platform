{
  "name": "icloush-digital-platform",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.4.1+sha512.c753b6c3ad7afa13af388fa6d808035a008e30ea9993f58c6663e2bc5ff21679aa834db094987129aa4d488b86df57f7b634981b2f827cdcacc698cc0cfb88af",
  "scripts": {
    "dev": "turbo run dev --filter=@icloush/admin",
    "build": "turbo run build",
    "check": "turbo run check",
    "test": "turbo run test",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @icloush/database db:generate",
    "db:migrate": "pnpm --filter @icloush/database db:migrate",
    "db:push": "pnpm --filter @icloush/database db:push",
    "admin:dev": "pnpm --filter @icloush/admin dev",
    "admin:build": "pnpm --filter @icloush/admin build"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.5.0",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "patchedDependencies": {
      "wouter@3.7.1": "patches/wouter@3.7.1.patch"
    },
    "overrides": {
      "tailwindcss>nanoid": "3.3.7"
    }
  }
}

{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "ADMIN_JWT_SECRET",
    "ADMIN_OAUTH_SERVER_URL",
    "JWT_SECRET",
    "OAUTH_SERVER_URL",
    "VITE_APP_ID",
    "DATABASE_URL",
    "NODE_ENV"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "check": {
      "dependsOn": ["^check"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": []
    },
    "db:generate": {
      "cache": false,
      "outputs": ["migrations/**"]
    },
    "db:migrate": {
      "cache": false,
      "outputs": []
    },
    "db:push": {
      "cache": false,
      "outputs": ["migrations/**"]
    }
  }
}
